# Fraetor 環境変数テンプレート
#
# このファイルを `.env` にコピーし、各 SSM パラメータパスを記入してください。
# `.env` は .gitignore で除外されます。実値は絶対にコミットしないでください。
#
# AWS 側で SecureString として作成済みの SSM パラメータパスを 4 つ指定します。
# 例: /myproj/api/azure_stt_key

FRAETOR_SSM_AZURE_SPEECH_KEY=
FRAETOR_SSM_MAI_API_KEY=
FRAETOR_SSM_MAI_ENDPOINT=
FRAETOR_SSM_VERTEX_SA=

# AWS 認証 (SSO セッションを使う前提)
# AWS_PROFILE=your-sso-profile
# AWS_REGION=ap-northeast-1
